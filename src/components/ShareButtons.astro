---
import { Link2 } from '@lucide/astro';
import LinkedinIcon from './icons/LinkedinIcon.astro';
import XIcon from './icons/XIcon.astro';

interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="flex items-center gap-2" aria-label="Share this post">
  <span class="text-sm text-fg-faint">Share:</span>
  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-fg-muted transition-colors hover:bg-bg-alt hover:text-primary"
    aria-label="Share on LinkedIn"
    target="_blank"
    rel="noopener"><LinkedinIcon class="h-4 w-4" /></a
  >
  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-fg-muted transition-colors hover:bg-bg-alt hover:text-primary"
    aria-label="Share on X (Twitter)"
    target="_blank"
    rel="noopener"><XIcon class="h-4 w-4" /></a
  >
  <button
    type="button"
    data-copy-url={url}
    class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-fg-muted transition-colors hover:bg-bg-alt hover:text-primary"
    aria-label="Copy link"><Link2 class="h-4 w-4" aria-hidden="true" /></button
  >
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy-url]').forEach((button) => {
    button.addEventListener('click', async () => {
      await navigator.clipboard.writeText(button.dataset.copyUrl ?? window.location.href);
      button.classList.add('text-success');
      setTimeout(() => button.classList.remove('text-success'), 1500);
    });
  });
</script>
