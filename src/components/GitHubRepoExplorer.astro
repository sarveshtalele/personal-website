---
import GithubIcon from './icons/GithubIcon.astro';
import { GITHUB_USERNAME } from '@lib/site';

interface Props {
  /** 'starred' shows a flat grid of the top N repos by stars. 'categorized' adds language pill filters above the grid. */
  mode?: 'starred' | 'categorized';
  limit?: number;
}
const { mode = 'starred', limit = 6 } = Astro.props;
const elementId = `github-repos-${mode}`;
---

<div data-mode={mode} data-limit={limit} data-username={GITHUB_USERNAME} id={elementId}>
  {
    mode === 'categorized' && (
      <div class="repo-filters mb-6 flex flex-wrap gap-2" hidden>
        <button type="button" class="repo-filter-all rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors" data-language="all">
          All
        </button>
      </div>
    )
  }
  <div class="repo-grid grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      Array.from({ length: mode === 'starred' ? limit : 6 }).map(() => (
        <div class="card h-[168px] animate-pulse p-6">
          <div class="h-4 w-2/3 rounded bg-bg-alt" />
          <div class="mt-3 h-3 w-full rounded bg-bg-alt" />
          <div class="mt-2 h-3 w-4/5 rounded bg-bg-alt" />
        </div>
      ))
    }
  </div>
</div>

<a
  href={`https://github.com/${GITHUB_USERNAME}`}
  class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary-strong"
  target="_blank"
  rel="noopener"
>
  <GithubIcon class="h-4 w-4" /> View full profile on GitHub →
</a>

<template id="repo-card-template">
  <a class="repo-link card card-hover flex h-full flex-col p-6" target="_blank" rel="noopener">
    <div class="repo-name text-lg font-semibold leading-snug tracking-tight text-fg transition-colors hover:text-primary"></div>
    <p class="repo-description mt-2 line-clamp-3 flex-1 text-sm text-fg-muted"></p>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span class="repo-language-badge hidden items-center gap-1.5 rounded-full border border-line bg-bg-alt px-2.5 py-1 text-xs font-medium text-fg-muted">
        <span class="repo-language-dot h-2 w-2 rounded-full"></span>
        <span class="repo-language-name"></span>
      </span>
      <span class="repo-stars rounded-full border border-line bg-bg-alt px-2.5 py-1 text-xs font-medium text-fg-muted"></span>
      <span class="repo-forks rounded-full border border-line bg-bg-alt px-2.5 py-1 text-xs font-medium text-fg-muted"></span>
    </div>
  </a>
</template>

<style>
  .repo-filter-all,
  .repo-filter {
    color: var(--fg-muted);
    border: 1px solid var(--border);
    background-color: var(--surface);
  }
  .repo-filter-all[aria-selected='true'],
  .repo-filter[aria-selected='true'] {
    color: var(--primary);
    background-color: var(--primary-soft);
    border-color: transparent;
  }
</style>

<script>
  interface Repo {
    name: string;
    html_url: string;
    description: string | null;
    language: string | null;
    stargazers_count: number;
    forks_count: number;
    fork: boolean;
  }

  const LANGUAGE_COLORS: Record<string, string> = {
    Python: '#3572A5',
    JavaScript: '#f1e05a',
    TypeScript: '#3178c6',
    Astro: '#ff5a03',
    HTML: '#e34c26',
    Shell: '#89e051',
    'Jupyter Notebook': '#DA5B0B',
  };

  function renderCard(template: HTMLTemplateElement, repo: Repo): DocumentFragment {
    const node = template.content.cloneNode(true) as DocumentFragment;
    const link = node.querySelector<HTMLAnchorElement>('.repo-link')!;
    link.href = repo.html_url;
    link.dataset.language = repo.language ?? 'Other';
    node.querySelector('.repo-name')!.textContent = repo.name;
    node.querySelector('.repo-description')!.textContent = repo.description ?? 'No description yet.';
    if (repo.language) {
      const badge = node.querySelector<HTMLElement>('.repo-language-badge')!;
      badge.classList.remove('hidden');
      badge.classList.add('inline-flex');
      node.querySelector('.repo-language-name')!.textContent = repo.language;
      (node.querySelector('.repo-language-dot') as HTMLElement).style.backgroundColor =
        LANGUAGE_COLORS[repo.language] ?? '#94a3b8';
    }
    node.querySelector('.repo-stars')!.textContent = `★ ${repo.stargazers_count}`;
    node.querySelector('.repo-forks')!.textContent = `⑂ ${repo.forks_count}`;
    return node;
  }

  function applyFilter(container: HTMLElement, language: string) {
    container.querySelectorAll<HTMLAnchorElement>('.repo-link').forEach((card) => {
      card.hidden = language !== 'all' && card.dataset.language !== language;
    });
  }

  async function init() {
    const containers = document.querySelectorAll<HTMLElement>('[id^="github-repos-"]');
    const template = document.getElementById('repo-card-template') as HTMLTemplateElement | null;
    if (!template) return;

    for (const container of containers) {
      const username = container.dataset.username;
      const mode = container.dataset.mode;
      const limit = Number(container.dataset.limit ?? 6);
      const grid = container.querySelector<HTMLElement>('.repo-grid')!;
      const filters = container.querySelector<HTMLElement>('.repo-filters');

      try {
        const res = await fetch(`https://api.github.com/users/${username}/repos?per_page=100&type=owner`);
        if (!res.ok) throw new Error(`GitHub API ${res.status}`);
        const repos: Repo[] = await res.json();
        const owned = repos.filter((r) => !r.fork);

        const list = mode === 'categorized' ? owned.sort((a, b) => b.stargazers_count - a.stargazers_count) : owned.sort((a, b) => b.stargazers_count - a.stargazers_count).slice(0, limit);

        grid.innerHTML = '';
        list.forEach((repo) => grid.appendChild(renderCard(template, repo)));

        if (mode === 'categorized' && filters) {
          const languages = [...new Set(owned.map((r) => r.language ?? 'Other'))].sort();
          const allButton = filters.querySelector<HTMLButtonElement>('.repo-filter-all')!;
          allButton.setAttribute('aria-selected', 'true');
          allButton.addEventListener('click', () => {
            filters.querySelectorAll('button').forEach((b) => b.setAttribute('aria-selected', String(b === allButton)));
            applyFilter(container, 'all');
          });

          for (const language of languages) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'repo-filter rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors';
            button.dataset.language = language;
            button.setAttribute('aria-selected', 'false');
            button.textContent = language;
            button.addEventListener('click', () => {
              filters.querySelectorAll('button').forEach((b) => b.setAttribute('aria-selected', String(b === button)));
              applyFilter(container, language);
            });
            filters.appendChild(button);
          }
          filters.hidden = false;
        }
      } catch {
        grid.innerHTML =
          '<p class="text-sm text-fg-faint">GitHub repositories are unavailable right now — see the GitHub profile instead.</p>';
      }
    }
  }
  init();
</script>
