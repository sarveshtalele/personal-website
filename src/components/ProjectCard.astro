---
import type { CollectionEntry } from 'astro:content';
import { ExternalLink, FolderGit2 } from '@lucide/astro';
import GithubIcon from './icons/GithubIcon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, description, techStack, github, demo, status } = project.data;

const statusStyles = {
  active: 'bg-primary-soft text-primary',
  completed: 'border border-line bg-bg-alt text-fg-muted',
  archived: 'border border-line bg-bg-alt text-fg-faint',
};
---

<article class="card card-hover group relative flex h-full flex-col p-6">
  <div class="flex items-start justify-between gap-3">
    <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary-soft text-primary">
      <FolderGit2 class="h-5 w-5" aria-hidden="true" />
    </span>
    <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-medium capitalize', statusStyles[status]]}>{status}</span>
  </div>
  <h3 class="mt-4 text-lg font-semibold leading-snug tracking-tight text-fg">
    <a href={`/projects/${project.id}`} class="transition-colors after:absolute after:inset-0 group-hover:text-primary">
      {title}
    </a>
  </h3>
  <p class="mt-2 line-clamp-3 flex-1 text-sm text-fg-muted">{description}</p>
  <div class="mt-4 flex flex-wrap gap-1.5">
    {
      techStack.slice(0, 5).map((tech) => (
        <span class="rounded-md border border-line bg-bg-alt px-2 py-0.5 text-xs font-medium text-fg-muted">{tech}</span>
      ))
    }
  </div>
  {
    (github || demo) && (
      <div class="relative z-10 mt-4 flex items-center gap-3 border-t border-line pt-4 text-sm">
        {github && (
          <a href={github} class="inline-flex items-center gap-1.5 font-medium text-fg-muted transition-colors hover:text-primary" target="_blank" rel="noopener">
            <GithubIcon class="h-4 w-4" /> Code
          </a>
        )}
        {demo && (
          <a href={demo} class="inline-flex items-center gap-1.5 font-medium text-fg-muted transition-colors hover:text-primary" target="_blank" rel="noopener">
            <ExternalLink class="h-4 w-4" aria-hidden="true" /> Live demo
          </a>
        )}
      </div>
    )
  }
</article>
