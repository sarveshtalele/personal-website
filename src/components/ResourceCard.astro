---
import type { CollectionEntry } from 'astro:content';
import { ExternalLink } from '@lucide/astro';

interface Props {
  resource: CollectionEntry<'resources'>;
}
const { resource } = Astro.props;
---

<a
  href={resource.data.url}
  target="_blank"
  rel="noopener"
  class="card card-hover group relative flex h-full flex-col p-6"
>
  <div class="flex items-center gap-3 text-xs text-fg-faint">
    <span>{resource.data.category}</span>
  </div>
  <h3 class="mt-3 flex items-center gap-1.5 text-lg font-semibold leading-snug tracking-tight text-fg transition-colors group-hover:text-primary">
    {resource.data.title}
    <ExternalLink class="h-4 w-4 shrink-0 text-fg-faint" aria-hidden="true" />
  </h3>
  <p class="mt-2 line-clamp-3 flex-1 text-sm text-fg-muted">{resource.data.description}</p>
  {
    resource.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {resource.data.tags.map((tag) => (
          <span class="rounded-md bg-bg-alt px-2 py-0.5 text-xs font-medium text-fg-faint">{tag}</span>
        ))}
      </div>
    )
  }
</a>
