---
import { Mail } from '@lucide/astro';
import { SITE } from '@lib/site';
---

<div class="card overflow-hidden">
  <div class="flex flex-col items-start gap-6 p-8 sm:flex-row sm:items-center sm:justify-between sm:p-10">
    <div class="max-w-md">
      <div class="flex items-center gap-2 text-primary">
        <Mail class="h-5 w-5" aria-hidden="true" />
        <p class="text-sm font-semibold uppercase tracking-widest">Stay in the loop</p>
      </div>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-fg">Get new posts in your inbox</h2>
      <p class="mt-2 text-sm text-fg-muted">
        Occasional deep dives on agentic AI, LangGraph, MCP, and production LLM engineering. No spam — unsubscribe anytime.
      </p>
    </div>
    <!--
      Wire this form to your provider (Buttondown, ConvertKit, Mailchimp…)
      by replacing the action URL. It degrades to a mailto link until then.
    -->
    <form
      action={`mailto:${SITE.email}?subject=Subscribe%20me%20to%20your%20newsletter`}
      method="get"
      class="flex w-full max-w-sm flex-col gap-3 sm:w-auto"
    >
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full rounded-xl border border-line bg-bg px-4 py-2.5 text-sm text-fg placeholder:text-fg-faint focus:border-primary sm:w-72"
      />
      <button
        type="submit"
        class="rounded-xl bg-primary px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-primary-strong dark:font-semibold dark:text-slate-900"
      >
        Subscribe
      </button>
    </form>
  </div>
</div>
