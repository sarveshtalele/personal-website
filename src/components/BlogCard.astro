---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@utils/format';
import Tag from './Tag.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
---

<article class="card card-hover group relative flex h-full flex-col p-6">
  <div class="flex items-center gap-3 text-xs text-fg-faint">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span aria-hidden="true">·</span>
    <span>{post.data.category}</span>
  </div>
  <h3 class="mt-3 text-lg font-semibold leading-snug tracking-tight text-fg">
    <a href={`/blog/${post.id}`} class="transition-colors after:absolute after:inset-0 group-hover:text-primary">
      {post.data.title}
    </a>
  </h3>
  <p class="mt-2 line-clamp-3 flex-1 text-sm text-fg-muted">{post.data.description}</p>
  {
    post.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {post.data.tags.slice(0, 3).map((tag) => (
          <Tag tag={tag} />
        ))}
      </div>
    )
  }
</article>
