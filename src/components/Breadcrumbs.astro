---
import { ChevronRight } from '@lucide/astro';
import { SITE } from '@lib/site';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ label: 'Home', href: '/' }, ...crumbs].map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.label,
    ...(crumb.href && { item: new URL(crumb.href, SITE.url).toString() }),
  })),
};
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-fg-faint">
    <li><a href="/" class="transition-colors hover:text-primary">Home</a></li>
    {
      crumbs.map((crumb, i) => (
        <li class="flex items-center gap-1.5">
          <ChevronRight class="h-3.5 w-3.5" aria-hidden="true" />
          {crumb.href && i < crumbs.length - 1 ? (
            <a href={crumb.href} class="transition-colors hover:text-primary">
              {crumb.label}
            </a>
          ) : (
            <span aria-current="page" class="max-w-[16rem] truncate text-fg-muted">
              {crumb.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
