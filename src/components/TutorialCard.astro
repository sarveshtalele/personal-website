---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '@utils/format';
import Tag from './Tag.astro';

interface Props {
  tutorial: CollectionEntry<'tutorials'>;
}
const { tutorial } = Astro.props;

const levelStyles = {
  beginner: 'bg-success/10 text-success',
  intermediate: 'bg-warning/10 text-warning',
  advanced: 'bg-primary-soft text-primary',
};
---

<article class="card card-hover group relative flex h-full min-w-0 flex-col p-6">
  <div class="flex items-center gap-3 text-xs text-fg-faint">
    <time datetime={tutorial.data.pubDate.toISOString()}>{formatDate(tutorial.data.pubDate)}</time>
    <span aria-hidden="true">·</span>
    <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium capitalize', levelStyles[tutorial.data.level]]}>
      {tutorial.data.level}
    </span>
  </div>
  <h3 class="mt-3 break-words text-lg font-semibold leading-snug tracking-tight text-fg">
    <a href={`/tutorials/${tutorial.id}`} class="transition-colors after:absolute after:inset-0 group-hover:text-primary">
      {tutorial.data.title}
    </a>
  </h3>
  <p class="mt-2 line-clamp-3 min-w-0 flex-1 break-words text-sm text-fg-muted">{tutorial.data.description}</p>
  {
    tutorial.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tutorial.data.tags.slice(0, 3).map((tag) => (
          <Tag tag={tag} />
        ))}
      </div>
    )
  }
</article>
