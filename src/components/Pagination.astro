---
import { ChevronLeft, ChevronRight } from '@lucide/astro';

interface Props {
  prevUrl?: string;
  nextUrl?: string;
  currentPage: number;
  totalPages: number;
}
const { prevUrl, nextUrl, currentPage, totalPages } = Astro.props;
---

{
  totalPages > 1 && (
    <nav aria-label="Pagination" class="mt-12 flex items-center justify-between">
      {prevUrl ? (
        <a href={prevUrl} class="inline-flex items-center gap-1.5 rounded-xl border border-line bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors hover:bg-bg-alt">
          <ChevronLeft class="h-4 w-4" aria-hidden="true" /> Newer
        </a>
      ) : (
        <span />
      )}
      <span class="text-sm text-fg-faint">
        Page {currentPage} of {totalPages}
      </span>
      {nextUrl ? (
        <a href={nextUrl} class="inline-flex items-center gap-1.5 rounded-xl border border-line bg-surface px-4 py-2 text-sm font-medium text-fg transition-colors hover:bg-bg-alt">
          Older <ChevronRight class="h-4 w-4" aria-hidden="true" />
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}
