---
import { ArrowRight } from '@lucide/astro';
import GithubIcon from './icons/GithubIcon.astro';
import LinkedinIcon from './icons/LinkedinIcon.astro';
import MediumIcon from './icons/MediumIcon.astro';
import OrcidIcon from './icons/OrcidIcon.astro';
import { SITE, SOCIALS } from '@lib/site';
import Button from './Button.astro';

const TAGLINE =
  'AI Engineer | Claude Certified Architect | NASA ADS | HarvardX AI Certified | 8× Awards @ TCS | Guinness World Record Holder';
---

<section class="relative overflow-hidden border-b border-line bg-bg-alt/60">
  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
    <div class="flex flex-col-reverse items-start gap-10 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-bold text-fg-muted">
          {SITE.role}
        </p>
        <h1 class="mt-6 text-3xl font-bold tracking-tight text-fg sm:text-4xl lg:text-5xl">
          Simple Problems. Complex Methods. Simple Explanations.
        </h1>
        <p class="mt-5 max-w-2xl text-base font-bold leading-relaxed text-fg-muted sm:text-lg">
          {TAGLINE}
        </p>
        <p class="mx-auto mt-8 max-w-xl text-center text-lg font-medium italic leading-relaxed tracking-wide text-fg-muted sm:text-xl">
          The mystery of human existence lies not in just staying alive, but in finding something to live for.
          <span class="mt-3 block text-sm font-medium not-italic tracking-widest text-fg-faint uppercase">Fyodor Dostoevsky · The Brothers Karamazov</span>
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <Button href="/claude" variant="primary" size="lg">
            Explore Claude <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </Button>
          <Button href="/projects" variant="secondary" size="lg">View Projects</Button>
          <Button href="https://topmate.io/sarveshtalele" variant="secondary" size="lg" external>Get in touch!</Button>
        </div>
      </div>

      <div class="flex shrink-0 flex-col items-center gap-4">
        <img
          src="/images/sarvesh-talele.jpg"
          alt={SITE.author}
          width="176"
          height="176"
          class="h-36 w-36 rounded-2xl border border-line object-cover shadow-sm sm:h-44 sm:w-44"
        />
        <div class="flex items-center gap-1">
          <a
            href={SOCIALS.github}
            class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-fg-muted transition-colors hover:bg-bg hover:text-fg"
            aria-label="GitHub"
            target="_blank"
            rel="me noopener"><GithubIcon class="h-5 w-5" /></a
          >
          <a
            href={SOCIALS.linkedin}
            class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-fg-muted transition-colors hover:bg-bg hover:text-fg"
            aria-label="LinkedIn"
            target="_blank"
            rel="me noopener"><LinkedinIcon class="h-5 w-5" /></a
          >
          <a
            href={SOCIALS.medium}
            class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-fg-muted transition-colors hover:bg-bg hover:text-fg"
            aria-label="Medium"
            target="_blank"
            rel="me noopener"><MediumIcon class="h-5 w-5" /></a
          >
          <a
            href={SOCIALS.orcid}
            class="inline-flex h-10 w-10 items-center justify-center rounded-xl text-fg-muted transition-colors hover:bg-bg hover:text-fg"
            aria-label="ORCID"
            target="_blank"
            rel="me noopener"><OrcidIcon class="h-5 w-5" /></a
          >
        </div>
      </div>
    </div>
  </div>
</section>
