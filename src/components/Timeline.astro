---
import type { CollectionEntry } from 'astro:content';
import { formatMonthYear } from '@utils/format';

interface Props {
  entries: CollectionEntry<'experience'>[];
  /** Max highlights to show per entry (0 = all) */
  maxHighlights?: number;
}
const { entries, maxHighlights = 0 } = Astro.props;
---

<ol class="relative space-y-10 border-l border-line pl-6">
  {
    entries.map((entry) => {
      const { company, role, location, startDate, endDate, current, highlights } = entry.data;
      const shown = maxHighlights > 0 ? highlights.slice(0, maxHighlights) : highlights;
      return (
        <li class="relative">
          <span class="absolute -left-[31px] top-1.5 h-2.5 w-2.5 rounded-full border-2 border-bg bg-primary" aria-hidden="true" />
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h3 class="text-lg font-semibold tracking-tight text-fg">{role}</h3>
            {current && <span class="rounded-full bg-primary-soft px-2.5 py-0.5 text-xs font-medium text-primary">Current</span>}
          </div>
          <p class="mt-0.5 text-sm text-fg-muted">
            {company}
            {location && <span class="text-fg-faint"> · {location}</span>}
          </p>
          <p class="mt-0.5 text-xs text-fg-faint">
            <time datetime={startDate.toISOString()}>{formatMonthYear(startDate)}</time>
            {' — '}
            {current || !endDate ? 'Present' : <time datetime={endDate.toISOString()}>{formatMonthYear(endDate)}</time>}
          </p>
          {shown.length > 0 && (
            <ul class="mt-3 space-y-1.5 text-sm text-fg-muted">
              {shown.map((highlight) => (
                <li class="flex gap-2">
                  <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-primary" aria-hidden="true" />
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          )}
        </li>
      );
    })
  }
</ol>
