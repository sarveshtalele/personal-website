---
import { FlaskConical, Trophy, ShieldCheck, ArrowRight } from '@lucide/astro';

const HIGHLIGHTS = [
  {
    icon: FlaskConical,
    title: 'NASA ADS Publication',
    description: 'Co-authored zero-shot accident detection research, indexed in the NASA Astrophysics Data System.',
    href: '/publications',
    linkLabel: 'Read the paper',
  },
  {
    icon: Trophy,
    title: 'Guinness World Record Holder',
    description: 'Participant in the record for Most Users to Take an Online Computer Programming Lesson in 24 Hours.',
    href: '/about',
    linkLabel: 'See achievements',
  },
  {
    icon: ShieldCheck,
    title: 'Claude Certified Architect',
    description: "Anthropic-certified on architecting production Claude systems — one of this site's core credentials.",
    href: '/certifications',
    linkLabel: 'View certifications',
  },
];

const EXPLORE = [
  { label: 'Full profile', href: '/about' },
  { label: 'Read the blog', href: '/blog' },
  { label: 'Browse projects', href: '/projects' },
];
---

<div class="card p-6 sm:p-8">
  <div class="grid gap-6 sm:grid-cols-3">
    {
      HIGHLIGHTS.map(({ icon: Icon, title, description, href, linkLabel }) => (
        <a href={href} class="group flex flex-col gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-primary-soft text-primary">
            <Icon class="h-5 w-5" aria-hidden="true" />
          </span>
          <div>
            <p class="font-semibold text-fg">{title}</p>
            <p class="mt-1 text-sm text-fg-muted">{description}</p>
          </div>
          <span class="mt-auto inline-flex items-center gap-1 text-sm font-medium text-primary transition-colors group-hover:text-primary-strong">
            {linkLabel} <ArrowRight class="h-3.5 w-3.5" aria-hidden="true" />
          </span>
        </a>
      ))
    }
  </div>

  <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3 border-t border-line pt-6 text-sm">
    <span class="font-semibold text-fg-faint">Explore</span>
    {
      EXPLORE.map((item) => (
        <a href={item.href} class="font-medium text-fg-muted transition-colors hover:text-primary">
          {item.label}
        </a>
      ))
    }
  </div>
</div>
