---
import { STATS } from '@lib/site';
---

<div class="glass-surface p-6 sm:p-8">
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
    {
      STATS.map((stat) => (
        <div class="glass-card flex flex-col justify-between p-5">
          <p class="text-2xl font-bold tracking-tight text-fg sm:text-3xl">{stat.value}</p>
          <p class="mt-2 text-xs leading-snug text-fg-muted">{stat.label}</p>
        </div>
      ))
    }
  </div>
</div>
