---
import type { CollectionEntry } from 'astro:content';
import { StickyNote } from '@lucide/astro';
import { formatDate } from '@utils/format';

interface Props {
  note: CollectionEntry<'notes'>;
}
const { note } = Astro.props;
---

<article class="card card-hover group relative flex h-full min-w-0 flex-col p-5">
  <div class="flex items-center gap-2 text-xs text-fg-faint">
    <StickyNote class="h-3.5 w-3.5" aria-hidden="true" />
    <time datetime={note.data.pubDate.toISOString()}>{formatDate(note.data.updatedDate ?? note.data.pubDate)}</time>
  </div>
  <h3 class="mt-2 break-words text-base font-semibold leading-snug tracking-tight text-fg">
    <a href={`/notes/${note.id}`} class="transition-colors after:absolute after:inset-0 group-hover:text-primary">
      {note.data.title}
    </a>
  </h3>
  <p class="mt-1.5 line-clamp-2 min-w-0 break-words text-sm text-fg-muted">{note.data.description}</p>
  {
    note.data.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {note.data.tags.slice(0, 3).map((tag) => (
          <span class="rounded-md bg-bg-alt px-2 py-0.5 text-xs text-fg-faint">{tag}</span>
        ))}
      </div>
    )
  }
</article>
