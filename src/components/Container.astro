---
interface Props {
  size?: 'default' | 'narrow' | 'wide';
  class?: string;
}
const { size = 'default', class: className } = Astro.props;
const widths = { narrow: 'max-w-3xl', default: 'max-w-6xl', wide: 'max-w-7xl' };
---

<div class:list={['mx-auto w-full px-4 sm:px-6', widths[size], className]}>
  <slot />
</div>
