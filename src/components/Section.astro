---
interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  href?: string;
  linkLabel?: string;
  class?: string;
  id?: string;
}
const { title, eyebrow, description, href, linkLabel = 'View all', class: className, id } = Astro.props;
---

<section class:list={['py-14 sm:py-16', className]} id={id}>
  {
    (title || eyebrow) && (
      <div class="mb-8 flex items-end justify-between gap-4">
        <div>
          {eyebrow && <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-primary">{eyebrow}</p>}
          {title && <h2 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl">{title}</h2>}
          {description && <p class="mt-2 max-w-2xl text-fg-muted">{description}</p>}
        </div>
        {href && (
          <a href={href} class="hidden shrink-0 text-sm font-medium text-primary transition-colors hover:text-primary-strong sm:inline-flex">
            {linkLabel} →
          </a>
        )}
      </div>
    )
  }
  <slot />
  {
    href && (
      <a href={href} class="mt-6 inline-flex text-sm font-medium text-primary transition-colors hover:text-primary-strong sm:hidden">
        {linkLabel} →
      </a>
    )
  }
</section>
