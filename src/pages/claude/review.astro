---
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout
  title="CCAR-F Question Bank: Learn & Review"
  description="All 360 CCAR-F practice questions in one scrollable place, grouped by domain and task statement, with full explanations, concept summaries, and a link to the exact Claude documentation page to read for each topic."
  eyebrow="Claude · Learn & Review"
  crumbs={[{ label: 'Claude', href: '/claude' }, { label: 'Learn & Review' }]}
>
  <div class="review" id="review-app" data-q="/claude/review/questions.json" data-c="/claude/review/concepts.json">
    <div class="review-warning" role="note">
      <strong>Unofficial study material.</strong> Original practice questions, not real exam questions and not
      affiliated with or endorsed by Anthropic. Every item links to the Claude documentation page that covers the
      concept, so you can learn it end to end.
    </div>
    <div class="review-toolbar">
      <input id="review-search" type="search" placeholder="Filter questions by keyword…" aria-label="Filter questions" />
      <label class="review-toggle"><input type="checkbox" id="review-testmode" /> Test mode (hide answers)</label>
      <span class="review-count" id="review-count"></span>
    </div>
    <div class="review-layout">
      <nav class="review-toc" id="review-toc" aria-label="Contents"><p class="review-muted">Loading…</p></nav>
      <div class="review-content" id="review-content"><p class="review-muted">Loading 360 questions…</p></div>
    </div>
  </div>
</PageLayout>

<style is:global>
  .review {
    --r-bg:#f0eee6; --r-card:#fffdf9; --r-ink:#262624; --r-muted:#6b6a63; --r-line:#e3ddd0; --r-chip:#f5efe4;
    --r-accent:#cc785c; --r-accent-strong:#b35f45; --r-good:#2f7d59; --r-good-soft:#e6f2ea; --r-bad:#b3402f; --r-bad-soft:#f6e5e1;
    color:var(--r-ink);
  }
  .dark .review {
    --r-bg:#262624; --r-card:#2f2e2b; --r-ink:#f0eee6; --r-muted:#b5b2a6; --r-line:#46443e; --r-chip:#3a3833;
    --r-accent:#e0956f; --r-accent-strong:#eeb290; --r-good:#7fc7a1; --r-good-soft:#2b3a33; --r-bad:#e8a08f; --r-bad-soft:#3d2c2a;
  }
  .review-muted { color:var(--r-muted); }
  .review-warning {
    border:1px solid var(--r-line); background:var(--r-chip); border-radius:.9rem; padding:.85rem 1.05rem;
    font-size:.9rem; line-height:1.5; margin-bottom:1rem;
  }
  .review-warning strong { color:var(--r-accent-strong); }
  .review-toolbar { display:flex; flex-wrap:wrap; gap:.75rem; align-items:center; margin-bottom:1rem; }
  #review-search {
    flex:1; min-width:220px; border:1px solid var(--r-line); background:var(--r-card); color:var(--r-ink);
    border-radius:.6rem; padding:.5rem .8rem; font-size:.9rem;
  }
  .review-toggle { display:inline-flex; align-items:center; gap:.4rem; font-size:.85rem; color:var(--r-muted); cursor:pointer; }
  .review-count { font-size:.8rem; color:var(--r-muted); font-weight:600; }

  .review-layout { display:grid; grid-template-columns:1fr; gap:1.5rem; }
  @media (min-width:1024px) { .review-layout { grid-template-columns:250px minmax(0,1fr); } }

  .review-toc { align-self:start; }
  @media (min-width:1024px) { .review-toc { position:sticky; top:1rem; max-height:calc(100vh - 2rem); overflow:auto; } }
  .review-toc details { border-bottom:1px solid var(--r-line); }
  .review-toc summary {
    cursor:pointer; padding:.5rem .25rem; font-weight:700; font-size:.9rem; list-style:none; display:flex;
    justify-content:space-between; gap:.5rem; align-items:center;
  }
  .review-toc summary::-webkit-details-marker { display:none; }
  .review-toc summary .toc-dom::before { content:'▸'; display:inline-block; margin-right:.45rem; font-size:.72em; color:var(--r-muted); transition:transform .15s ease; }
  .review-toc details[open] summary .toc-dom::before { transform:rotate(90deg); }
  .review-toc details[open] > summary .toc-dom { color:var(--r-accent); }
  .review-toc .toc-w { font-size:.7rem; font-weight:600; color:var(--r-accent); }
  .review-toc a { display:block; padding:.28rem .25rem .28rem .75rem; font-size:.82rem; color:var(--r-muted); text-decoration:none; border-left:2px solid transparent; }
  .review-toc a:hover { color:var(--r-ink); }
  .review-toc a.active { color:var(--r-accent); border-left-color:var(--r-accent); font-weight:600; }

  .r-domain { margin-top:2.5rem; scroll-margin-top:1rem; }
  .r-domain:first-child { margin-top:0; }
  .r-domain-head { border-bottom:2px solid var(--r-line); padding-bottom:.4rem; }
  .r-domain-head h2 { font-size:1.4rem; font-weight:800; letter-spacing:-.01em; }
  .r-domain-head .w { font-size:.8rem; color:var(--r-accent); font-weight:700; text-transform:uppercase; letter-spacing:.1em; }

  .r-concepts { margin-top:1rem; display:grid; gap:.6rem; }
  .r-concept { border:1px solid var(--r-line); background:var(--r-chip); border-radius:.7rem; padding:.7rem .9rem; font-size:.88rem; }
  .r-concept .t { font-weight:700; color:var(--r-ink); }
  .r-concept .s { color:var(--r-muted); margin-top:.15rem; line-height:1.5; }
  .r-concept a { color:var(--r-accent); font-weight:600; text-decoration:none; white-space:nowrap; }
  .r-concept a:hover { text-decoration:underline; }

  .r-task { margin-top:1.6rem; scroll-margin-top:1rem; }
  .r-task h3 { font-size:1.05rem; font-weight:700; color:var(--r-accent-strong); }

  /* content-visibility lets the browser skip layout/paint for off-screen
     cards — critical with 360 questions on one page. */
  .r-q { border:1px solid var(--r-line); background:var(--r-card); border-radius:.8rem; padding:1.1rem 1.2rem; margin-top:.9rem; box-shadow:var(--shadow-card); content-visibility:auto; contain-intrinsic-size:0 260px; }
  .r-q .qid { font-size:.72rem; font-weight:700; color:var(--r-muted); letter-spacing:.03em; }
  .r-q .stem { font-weight:600; line-height:1.55; margin-top:.3rem; }
  .r-opts { display:grid; gap:.45rem; margin-top:.8rem; }
  .r-opt { display:flex; gap:.6rem; align-items:flex-start; border:1px solid var(--r-line); border-radius:.6rem; padding:.55rem .75rem; font-size:.92rem; line-height:1.5; }
  .r-opt .l { flex:none; width:1.5rem; height:1.5rem; border-radius:.4rem; display:grid; place-items:center; border:1px solid var(--r-line); font-weight:700; font-size:.78rem; background:var(--r-chip); }
  .r-answered .r-opt.correct { border-color:var(--r-good); background:var(--r-good-soft); }
  .r-answered .r-opt.correct .l { background:var(--r-good); color:#fff; border-color:var(--r-good); }
  .r-ans { margin-top:.85rem; border:1px solid var(--r-line); border-radius:.6rem; overflow:hidden; }
  .r-ans .row { padding:.6rem .85rem; font-size:.88rem; line-height:1.55; border-top:1px solid var(--r-line); }
  .r-ans .row:first-child { border-top:none; }
  .r-ans .row.good { background:var(--r-good-soft); }
  .r-ans .row .lab { font-weight:700; }
  .r-ans .row.good .lab { color:var(--r-good); }
  .r-ans .row.why .lab { color:var(--r-muted); }
  .r-doc { margin-top:.7rem; font-size:.85rem; }
  .r-doc a { color:var(--r-accent); font-weight:600; text-decoration:none; }
  .r-doc a:hover { text-decoration:underline; }
  code { background:var(--r-chip); border:1px solid var(--r-line); border-radius:4px; padding:0 .25rem; font-size:.85em; }

  /* test mode: hide answers until revealed per card */
  .review.testmode .r-ans, .review.testmode .r-doc { display:none; }
  .review.testmode .r-q.revealed .r-ans, .review.testmode .r-q.revealed .r-doc { display:block; }
  .review.testmode .r-answered .r-opt.correct { border-color:var(--r-line); background:var(--r-card); }
  .review.testmode .r-q.revealed .r-opt.correct { border-color:var(--r-good); background:var(--r-good-soft); }
  .review.testmode .r-q.revealed .r-opt.correct .l { background:var(--r-good); color:#fff; border-color:var(--r-good); }
  .r-reveal { display:none; margin-top:.7rem; }
  .review.testmode .r-q:not(.revealed) .r-reveal { display:inline-flex; }
  .r-reveal button { border:1px solid var(--r-line); background:var(--r-chip); color:var(--r-ink); border-radius:.5rem; padding:.35rem .8rem; font-size:.82rem; font-weight:600; cursor:pointer; }
</style>

<script>
  type Q = { id:string; domain:number; task:string; ptask:string; scenario:number; stem:string;
    options:Record<'A'|'B'|'C'|'D',string>; answer:string; explanation:string; distractors:Record<string,string>;
    official:boolean; docLabel:string; docUrl:string; };
  type Concept = { domain:number; domainName:string; weight:string; task:string; title:string; summary:string; docUrl:string; };
  const LETTERS = ['A','B','C','D'] as const;

  const root = document.getElementById('review-app')!;
  const tocEl = document.getElementById('review-toc')!;
  const contentEl = document.getElementById('review-content')!;
  const countEl = document.getElementById('review-count')!;

  function esc(s:string){ return s.replace(/[&<>"']/g,(c)=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]!)); }
  function md(s:string){ let o=esc(s); o=o.replace(/`([^`]+)`/g,(_,t)=>`<code>${t}</code>`);
    o=o.replace(/\*\*([^*]+)\*\*/g,(_,t)=>`<strong>${t}</strong>`); o=o.replace(/\*([^*]+)\*/g,(_,t)=>`<em>${t}</em>`); return o; }

  function questionHtml(q:Q):string {
    const opts = LETTERS.map((l)=>{
      const cls = 'r-opt'+(l===q.answer?' correct':'');
      return `<div class="${cls}"><span class="l">${l}</span><span>${md(q.options[l])}</span></div>`;
    }).join('');
    const others = LETTERS.filter((l)=>l!==q.answer).map((l)=>{
      const r=q.distractors[l]; return r?`<div class="row why"><span class="lab">Why not ${l}:</span> ${md(r)}</div>`:'';
    }).join('');
    return `<div class="r-q r-answered" data-text="${esc((q.stem+' '+Object.values(q.options).join(' ')).toLowerCase())}">
      <div class="qid">${q.id}${q.official?' · exam-style ★':''}</div>
      <p class="stem">${md(q.stem)}</p>
      <div class="r-opts">${opts}</div>
      <div class="r-reveal"><button type="button">Reveal answer</button></div>
      <div class="r-ans">
        <div class="row good"><span class="lab">Correct answer: ${q.answer}.</span> ${md(q.explanation)}</div>
        ${others}
      </div>
      <p class="r-doc">📖 If unsure, review: <a href="${q.docUrl}" target="_blank" rel="noopener">${esc(q.docLabel)} →</a></p>
    </div>`;
  }

  async function boot(){
    let questions:Q[], concepts:Concept[];
    try {
      [questions, concepts] = await Promise.all([
        fetch(root.dataset.q!).then((r)=>{ if(!r.ok) throw 0; return r.json(); }),
        fetch(root.dataset.c!).then((r)=>{ if(!r.ok) throw 0; return r.json(); }),
      ]);
    } catch { contentEl.innerHTML = '<p class="review-muted">Couldn\'t load the question bank. Please refresh.</p>'; return; }

    const domains = [...new Set(questions.map((q)=>q.domain))].sort();
    const conceptsByDom:Record<number,Concept[]> = {};
    concepts.forEach((c)=>{ (conceptsByDom[c.domain] ??= []).push(c); });

    let toc = '', content = '';
    for (const d of domains) {
      const dq = questions.filter((q)=>q.domain===d);
      const dname = conceptsByDom[d]?.[0]?.domainName ?? `Domain ${d}`;
      const weight = conceptsByDom[d]?.[0]?.weight ?? '';
      // group by task
      const tasks = [...new Set(dq.map((q)=>q.ptask))].sort();
      // TOC (collapsible dropdown per domain)
      toc += `<details data-domain="${d}"><summary><span class="toc-dom">D${d} · ${esc(dname)}</span><span class="toc-w">${weight}</span></summary>`;
      for (const t of tasks) {
        const tc = conceptsByDom[d]?.find((c)=>c.task===t);
        const tid = 't' + t.replace('.', '-');
        const title = tc?.title ?? '';
        const short = title.length > 38 ? title.slice(0, 38) + '…' : title;
        toc += `<a href="#${tid}" data-toc="${tid}">${t} · ${esc(short)} <span style="opacity:.6">(${dq.filter((q)=>q.ptask===t).length})</span></a>`;
      }
      toc += `</details>`;
      // content: domain head + concepts + questions
      content += `<section class="r-domain" id="d${d}"><div class="r-domain-head"><p class="w">Domain ${d} · ${weight}</p><h2>${esc(dname)}</h2></div>`;
      content += `<div class="r-concepts">`;
      for (const c of (conceptsByDom[d]??[])) {
        content += `<div class="r-concept"><div style="display:flex;justify-content:space-between;gap:.75rem;align-items:baseline">
          <span class="t">${c.task} · ${esc(c.title)}</span>
          <a href="${c.docUrl}" target="_blank" rel="noopener">Read the docs →</a></div>
          <div class="s">${md(c.summary)}</div></div>`;
      }
      content += `</div>`;
      for (const t of tasks) {
        const tc = conceptsByDom[d]?.find((c)=>c.task===t);
        content += `<div class="r-task" id="t${t.replace('.','-')}" data-domain="${d}"><h3>Task ${t}${tc?`: ${esc(tc.title)}`:''}</h3>`;
        for (const q of dq.filter((x)=>x.ptask===t)) content += questionHtml(q);
        content += `</div>`;
      }
      content += `</section>`;
    }
    tocEl.innerHTML = toc;
    contentEl.innerHTML = content;
    countEl.textContent = `${questions.length} questions`;

    // reveal buttons (test mode)
    contentEl.addEventListener('click', (e)=>{
      const btn = (e.target as HTMLElement).closest('.r-reveal button');
      if (btn) btn.closest('.r-q')?.classList.add('revealed');
    });
    // test mode toggle
    document.getElementById('review-testmode')!.addEventListener('change', (e)=>{
      const on = (e.target as HTMLInputElement).checked;
      root.classList.toggle('testmode', on);
      if (!on) contentEl.querySelectorAll('.r-q.revealed').forEach((q)=>q.classList.remove('revealed'));
    });
    // search filter
    const search = document.getElementById('review-search') as HTMLInputElement;
    search.addEventListener('input', ()=>{
      const term = search.value.trim().toLowerCase();
      let shown = 0;
      contentEl.querySelectorAll<HTMLElement>('.r-q').forEach((card)=>{
        const match = !term || (card.dataset.text ?? '').includes(term);
        card.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      // hide empty task/domain groups
      contentEl.querySelectorAll<HTMLElement>('.r-task').forEach((t)=>{
        const any = [...t.querySelectorAll<HTMLElement>('.r-q')].some((q)=>q.style.display!=='none');
        t.style.display = any ? '' : 'none';
      });
      contentEl.querySelectorAll<HTMLElement>('.r-domain').forEach((s)=>{
        const any = [...s.querySelectorAll<HTMLElement>('.r-q')].some((q)=>q.style.display!=='none');
        s.querySelectorAll<HTMLElement>('.r-concepts, .r-domain-head').forEach((el)=>{ el.style.opacity = any?'1':'0.4'; });
      });
      countEl.textContent = term ? `${shown} match${shown===1?'':'es'}` : `${questions.length} questions`;
    });
    // scrollspy: as the page scrolls, highlight the current task and open its
    // domain dropdown (accordion follows scroll). Uses scroll position rather
    // than IntersectionObserver so it stays accurate for tall sections.
    const taskLinks = new Map<string,HTMLElement>();
    tocEl.querySelectorAll<HTMLElement>('a[data-toc]').forEach((a)=>taskLinks.set(a.dataset.toc!, a));
    const detailsEls = [...tocEl.querySelectorAll<HTMLDetailsElement>('details[data-domain]')];
    const taskEls = [...contentEl.querySelectorAll<HTMLElement>('.r-task')];
    let activeTask = '', activeDom = '', ticking = false, userToggled = false;
    // if the visitor manually opens/closes a dropdown, stop auto-managing them
    detailsEls.forEach((d)=>d.querySelector('summary')?.addEventListener('click', ()=>{ userToggled = true; }));
    function spy(){
      ticking = false;
      const line = 150;
      let cur: HTMLElement | null = taskEls[0] ?? null;
      for (const el of taskEls){ if (el.getBoundingClientRect().top <= line) cur = el; else break; }
      if (!cur) return;
      const tid = cur.id, dom = cur.dataset.domain ?? '';
      if (tid !== activeTask){
        activeTask = tid;
        taskLinks.forEach((a)=>a.classList.remove('active'));
        const link = taskLinks.get(tid);
        if (link){ link.classList.add('active'); link.scrollIntoView({ block:'nearest' }); }
      }
      if (dom !== activeDom){
        activeDom = dom;
        if (!userToggled) detailsEls.forEach((d)=>{ d.open = (d.dataset.domain === dom); });
      }
    }
    window.addEventListener('scroll', ()=>{ if(!ticking){ ticking = true; requestAnimationFrame(spy); } }, { passive:true });
    // clicking a TOC link jumps and re-enables auto-accordion
    tocEl.addEventListener('click', (e)=>{ if ((e.target as HTMLElement).closest('a[data-toc]')) userToggled = false; });
    spy();
  }
  boot();
</script>
