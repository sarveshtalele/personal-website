---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import { Sparkles, ArrowRight, ShieldCheck, ExternalLink, Coffee, Clock } from '@lucide/astro';
import { byDateDesc, formatDate } from '@utils/format';

const certifications = (await getCollection('certifications'))
  .filter((c) => c.data.title.includes('Claude Certified Architect'))
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const claudePosts = (await getCollection('blog', ({ data }) => !data.draft && data.tags.includes('Claude'))).sort(
  byDateDesc((p) => p.data.pubDate)
);
---

<PageLayout
  title="Claude"
  description="Claude Certified Architect badges, guides, and products — everything on this site specific to the Claude ecosystem."
  eyebrow="Anthropic · Claude"
  crumbs={[{ label: 'Claude' }]}
>
  <div class="claude-page">
    <div class="claude-hero relative overflow-hidden rounded-2xl p-8 sm:p-12">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
        <Sparkles class="h-3.5 w-3.5" aria-hidden="true" /> Claude Certified Architect
      </span>
      <h1 class="mt-4 max-w-2xl text-3xl font-bold tracking-tight text-(--claude-ink) sm:text-4xl">
        Everything I build and write about Claude, in one place.
      </h1>
      <p class="mt-3 max-w-xl text-(--claude-ink-muted)">
        Both Claude architecture tracks, exam guides, and the sessions I run for people navigating the Claude
        ecosystem — whether you're technical or not.
      </p>
    </div>

    <section class="mt-14">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-(--claude-accent)">Dashboard</p>
      <div class="grid gap-6 lg:grid-cols-3">
        {
          certifications.map((cert) => (
            <div class="claude-card flex flex-col items-center gap-4 rounded-2xl p-6 text-center">
              {cert.data.badge && (
                <img
                  src={cert.data.badge}
                  alt={cert.data.title}
                  width="120"
                  height="120"
                  class="h-28 w-28 rounded-xl object-contain"
                />
              )}
              <div>
                <p class="flex items-center justify-center gap-1.5 text-sm font-semibold text-(--claude-ink)">
                  <ShieldCheck class="h-4 w-4 text-(--claude-accent)" aria-hidden="true" />
                  {cert.data.title}
                </p>
                <p class="mt-1 text-xs text-(--claude-ink-muted)">{cert.data.issuer} · {formatDate(cert.data.date)}</p>
              </div>
              {cert.data.credentialUrl && (
                <a
                  href={cert.data.credentialUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1 text-xs font-medium text-(--claude-accent) hover:underline"
                >
                  Verify <ExternalLink class="h-3 w-3" aria-hidden="true" />
                </a>
              )}
            </div>
          ))
        }

        <div class="claude-card claude-card-accent flex flex-col justify-between gap-6 rounded-2xl p-6 sm:col-span-2 lg:col-span-1">
          <div>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
              <Coffee class="h-3.5 w-3.5" aria-hidden="true" /> My Claude Products
            </span>
            <p class="mt-3 text-sm text-(--claude-ink-muted)">
              1:1 Claude architecture reviews, exam prep sessions, and build sessions — book directly, no
              back-and-forth.
            </p>
          </div>
          <a
            href="https://topmate.io/sarveshtalele"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-(--claude-accent) px-5 py-3 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5"
          >
            Book on Topmate <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    <section class="mt-14">
      <div class="mb-6 flex items-end justify-between gap-4">
        <p class="text-sm font-semibold uppercase tracking-widest text-(--claude-accent)">Blogs</p>
        <a
          href="/blog/tags/claude"
          class="hidden shrink-0 text-sm font-medium text-(--claude-accent) transition-colors hover:underline sm:inline-flex"
        >
          View all →
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {claudePosts.map((post) => <BlogCard post={post} />)}

        <article class="claude-card flex h-full min-w-0 flex-col p-6 opacity-80">
          <div class="flex items-center gap-3 text-xs text-(--claude-ink-muted)">
            <Clock class="h-3.5 w-3.5" aria-hidden="true" />
            <span>Claude</span>
          </div>
          <h3 class="mt-3 break-words text-lg font-semibold leading-snug tracking-tight text-(--claude-ink)">
            How to prepare for the CCA-P (Professional) exam
          </h3>
          <p class="mt-2 min-w-0 flex-1 break-words text-sm text-(--claude-ink-muted)">
            The Professional-track write-up is on the way — once I've sat the exam, the full study path lands
            here.
          </p>
          <span class="mt-4 inline-flex w-fit items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1.5 text-xs font-semibold text-(--claude-ink-muted)">
            <Clock class="h-3.5 w-3.5" aria-hidden="true" /> Coming soon
          </span>
        </article>
      </div>
      <a href="/blog/tags/claude" class="mt-6 inline-flex text-sm font-medium text-(--claude-accent) hover:underline sm:hidden">
        View all →
      </a>
    </section>
  </div>
</PageLayout>

<style>
  /*
   * Self-contained Claude brand palette (Anthropic's warm clay/cream
   * language), scoped to this page only — same isolation pattern as
   * SpaceDashboard's cosmic theme. Doesn't touch the site's global tokens.
   */
  .claude-page {
    --claude-bg: #f0eee6;
    --claude-card: #fffdf9;
    --claude-ink: #262624;
    --claude-ink-muted: #6b6a63;
    --claude-line: #e3ddd0;
    --claude-chip: #f5efe4;
    --claude-accent: #cc785c;
    --claude-accent-strong: #b35f45;
  }
  :global(.dark) .claude-page {
    --claude-bg: #262624;
    --claude-card: #2f2e2b;
    --claude-ink: #f0eee6;
    --claude-ink-muted: #b5b2a6;
    --claude-line: #46443e;
    --claude-chip: #3a3833;
    --claude-accent: #e0956f;
    --claude-accent-strong: #eeb290;
  }

  .claude-hero {
    background: linear-gradient(135deg, var(--claude-bg) 0%, var(--claude-chip) 100%);
    border: 1px solid var(--claude-line);
  }

  .claude-card {
    background-color: var(--claude-card);
    border: 1px solid var(--claude-line);
    box-shadow: var(--shadow-card);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .claude-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }
  .claude-card-accent {
    background: linear-gradient(160deg, var(--claude-card) 0%, var(--claude-chip) 100%);
  }
</style>
