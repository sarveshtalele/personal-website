---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import { Sparkles, ArrowRight, ShieldCheck, ExternalLink, Coffee, Clock, GraduationCap, BookOpen, FileText } from '@lucide/astro';
import { formatDate } from '@utils/format';

const EXAM_REPO = 'https://github.com/sarveshtalele/claude-architect-exam-guide';
const EXAM_REPO_FOUNDATIONS = 'https://github.com/sarveshtalele/claude-architect-exam-guide/tree/main/foundations';
const TOPMATE = 'https://topmate.io/sarveshtalele';

const certifications = (await getCollection('certifications'))
  .filter((c) => c.data.title.includes('Claude Certified Architect'))
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<PageLayout
  title="Claude"
  description="Claude Certified Architect badges, guides, and products — everything on this site specific to the Claude ecosystem."
  eyebrow="Anthropic · Claude"
  crumbs={[{ label: 'Claude' }]}
>
  <div class="claude-page">
    <div class="claude-hero relative overflow-hidden rounded-2xl p-8 sm:p-12">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
        <Sparkles class="h-3.5 w-3.5" aria-hidden="true" /> Claude Certified Architect
      </span>
      <h1 class="mt-4 max-w-2xl text-3xl font-bold tracking-tight text-(--claude-ink) sm:text-4xl">
        Everything I build and write about Claude, in one place.
      </h1>
      <p class="mt-3 max-w-xl text-(--claude-ink-muted)">
        Both Claude architecture tracks, exam guides, and the sessions I run for people navigating the Claude
        ecosystem — whether you're technical or not.
      </p>
    </div>

    {/* Mock exam — the free practice product */}
    <section class="mt-14">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-(--claude-accent)">Practice</p>
      <div class="claude-card claude-card-accent overflow-hidden rounded-2xl p-6 sm:p-8">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
              <GraduationCap class="h-3.5 w-3.5" aria-hidden="true" /> Free CCAR-F Mock Exam
            </span>
            <h2 class="mt-3 text-2xl font-bold tracking-tight text-(--claude-ink)">
              Sit a full mock exam for the Claude Certified Architect – Foundations exam
            </h2>
            <p class="mt-2 text-(--claude-ink-muted)">
              A timed, 60-question mock exam that mirrors the real CCAR-F format — scored by domain — plus an
              untimed practice mode with full explanations for every question. Drawn from a bank of 360 scenario-based
              practice questions.
            </p>
            <p class="claude-warning mt-4 text-sm">
              <strong>Heads up:</strong> these are <strong>not official exam questions</strong> and are not affiliated
              with or endorsed by Anthropic. They're written to strengthen your understanding and reflect the
              <em>style</em> of scenario-based reasoning the exam rewards.
            </p>
          </div>
          <div class="flex shrink-0 flex-col gap-3">
            <a
              href="/claude/quiz"
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-(--claude-accent) px-5 py-3 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5"
            >
              Start the mock exam <ArrowRight class="h-4 w-4" aria-hidden="true" />
            </a>
            <a
              href={TOPMATE}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-xl border border-(--claude-line) bg-(--claude-chip) px-5 py-3 text-sm font-semibold text-(--claude-ink) transition-transform hover:-translate-y-0.5"
            >
              Get all 360 questions <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Dashboard — certifications + products (unchanged three cards) */}
    <section class="mt-14">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-(--claude-accent)">Dashboard</p>
      <div class="grid gap-6 lg:grid-cols-3">
        {
          certifications.map((cert) => (
            <div class="claude-card flex flex-col items-center gap-4 rounded-2xl p-6 text-center">
              {cert.data.badge && (
                <img
                  src={cert.data.badge}
                  alt={cert.data.title}
                  width="120"
                  height="120"
                  class="h-28 w-28 rounded-xl object-contain"
                />
              )}
              <div>
                <p class="flex items-center justify-center gap-1.5 text-sm font-semibold text-(--claude-ink)">
                  <ShieldCheck class="h-4 w-4 text-(--claude-accent)" aria-hidden="true" />
                  {cert.data.title}
                </p>
                <p class="mt-1 text-xs text-(--claude-ink-muted)">{cert.data.issuer} · {formatDate(cert.data.date)}</p>
              </div>
              {cert.data.credentialUrl && (
                <a
                  href={cert.data.credentialUrl}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1 text-xs font-medium text-(--claude-accent) hover:underline"
                >
                  Verify <ExternalLink class="h-3 w-3" aria-hidden="true" />
                </a>
              )}
            </div>
          ))
        }

        <div class="claude-card claude-card-accent flex flex-col justify-between gap-6 rounded-2xl p-6 sm:col-span-2 lg:col-span-1">
          <div>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
              <Coffee class="h-3.5 w-3.5" aria-hidden="true" /> My Claude Products
            </span>
            <p class="mt-3 text-sm text-(--claude-ink-muted)">
              1:1 Claude architecture reviews, exam prep sessions, and build sessions — book directly, no
              back-and-forth.
            </p>
          </div>
          <a
            href={TOPMATE}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-(--claude-accent) px-5 py-3 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5"
          >
            Book on Topmate <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>

    {/* Exam prep — replaces the old blog section */}
    <section class="mt-14">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-(--claude-accent)">Exam Prep</p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/claude/foundations" class="claude-card flex h-full flex-col gap-3 rounded-2xl p-6">
          <span class="inline-flex w-fit items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
            <BookOpen class="h-3.5 w-3.5" aria-hidden="true" /> CCAR-F
          </span>
          <h3 class="text-lg font-semibold leading-snug tracking-tight text-(--claude-ink)">
            Preparing for the Claude Foundation exam
          </h3>
          <p class="flex-1 text-sm text-(--claude-ink-muted)">
            The blueprint, domains, task statements, and a study plan for the Foundations (CCAR-F) tier — plus a link
            straight into the mock exam.
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-(--claude-accent)">
            Open the guide <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </span>
        </a>

        <a href={EXAM_REPO_FOUNDATIONS} target="_blank" rel="noopener" class="claude-card flex h-full flex-col gap-3 rounded-2xl p-6">
          <span class="inline-flex w-fit items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink)">
            <FileText class="h-3.5 w-3.5" aria-hidden="true" /> GitHub
          </span>
          <h3 class="text-lg font-semibold leading-snug tracking-tight text-(--claude-ink)">
            Exam guide &amp; resources repo
          </h3>
          <p class="flex-1 text-sm text-(--claude-ink-muted)">
            The open-source study hub: Foundations blueprint, a slash-command study skill, and copy-paste prompt packs
            for learning, practice, and mock tests.
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-medium text-(--claude-accent)">
            View on GitHub <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
          </span>
        </a>

        <div class="claude-card flex h-full flex-col gap-3 rounded-2xl p-6 opacity-80">
          <span class="inline-flex w-fit items-center gap-1.5 rounded-full border border-(--claude-line) bg-(--claude-chip) px-3 py-1 text-xs font-medium text-(--claude-ink-muted)">
            <Clock class="h-3.5 w-3.5" aria-hidden="true" /> CCAR-P · Coming soon
          </span>
          <h3 class="text-lg font-semibold leading-snug tracking-tight text-(--claude-ink)">
            Preparing for the Professional exam
          </h3>
          <p class="flex-1 text-sm text-(--claude-ink-muted)">
            The Professional-track write-up and practice set are on the way — once I've sat the exam, the full study
            path lands here.
          </p>
          <a href={EXAM_REPO} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-sm font-medium text-(--claude-accent) hover:underline">
            Browse the repo <ExternalLink class="h-3.5 w-3.5" aria-hidden="true" />
          </a>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  /*
   * Self-contained Claude brand palette (Anthropic's warm clay/cream
   * language), scoped to this page only — same isolation pattern as
   * SpaceDashboard's cosmic theme. Doesn't touch the site's global tokens.
   */
  .claude-page {
    --claude-bg: #f0eee6;
    --claude-card: #fffdf9;
    --claude-ink: #262624;
    --claude-ink-muted: #6b6a63;
    --claude-line: #e3ddd0;
    --claude-chip: #f5efe4;
    --claude-accent: #cc785c;
    --claude-accent-strong: #b35f45;
  }
  :global(.dark) .claude-page {
    --claude-bg: #262624;
    --claude-card: #2f2e2b;
    --claude-ink: #f0eee6;
    --claude-ink-muted: #b5b2a6;
    --claude-line: #46443e;
    --claude-chip: #3a3833;
    --claude-accent: #e0956f;
    --claude-accent-strong: #eeb290;
  }

  .claude-hero {
    background: linear-gradient(135deg, var(--claude-bg) 0%, var(--claude-chip) 100%);
    border: 1px solid var(--claude-line);
  }

  .claude-card {
    background-color: var(--claude-card);
    border: 1px solid var(--claude-line);
    box-shadow: var(--shadow-card);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  a.claude-card:hover,
  .claude-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }
  .claude-card-accent {
    background: linear-gradient(160deg, var(--claude-card) 0%, var(--claude-chip) 100%);
  }
  .claude-warning {
    border: 1px solid var(--claude-line);
    background: var(--claude-chip);
    color: var(--claude-ink);
    border-radius: 0.75rem;
    padding: 0.7rem 0.9rem;
    line-height: 1.5;
  }
  .claude-warning strong {
    color: var(--claude-accent-strong);
  }
</style>
