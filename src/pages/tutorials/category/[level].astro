---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import TutorialCard from '@components/TutorialCard.astro';
import { byDateDesc } from '@utils/format';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  const levels = [...new Set(tutorials.map((t) => t.data.level))];
  return levels.map((level) => ({
    params: { level },
    props: { level, tutorials: tutorials.filter((t) => t.data.level === level) },
  }));
}

const { level, tutorials } = Astro.props;
const sorted = tutorials.sort(byDateDesc((t) => t.data.pubDate));
---

<PageLayout
  title={`${level.charAt(0).toUpperCase()}${level.slice(1)} tutorials`}
  description={`${level} tutorials on agentic AI and LLM engineering.`}
  eyebrow="Level"
  crumbs={[{ label: 'Tutorials', href: '/tutorials' }, { label: level }]}
>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((tutorial) => <TutorialCard tutorial={tutorial} />)}
  </div>
</PageLayout>
