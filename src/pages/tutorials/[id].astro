---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { mdxComponents } from '@components/mdx-components';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((tutorial) => ({ params: { id: tutorial.id }, props: { tutorial } }));
}

const { tutorial } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(tutorial);
const minutesRead = (remarkPluginFrontmatter as { minutesRead?: number }).minutesRead;
---

<ArticleLayout
  title={tutorial.data.title}
  description={tutorial.data.description}
  pubDate={tutorial.data.pubDate}
  updatedDate={tutorial.data.updatedDate}
  minutesRead={minutesRead}
  tags={tutorial.data.tags}
  category={tutorial.data.level}
  headings={headings}
  crumbs={[{ label: 'Tutorials', href: '/tutorials' }, { label: tutorial.data.title }]}
  showShare
  showComments
>
  <Content components={mdxComponents} />
</ArticleLayout>
