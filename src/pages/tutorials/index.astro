---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import TutorialCard from '@components/TutorialCard.astro';
import { byDateDesc } from '@utils/format';

const tutorials = (await getCollection('tutorials')).sort(byDateDesc((t) => t.data.pubDate));
const levels = [...new Set(tutorials.map((t) => t.data.level))];
---

<PageLayout
  title="Tutorials"
  description="Step-by-step, hands-on guides for building agentic AI systems, from first principles to production."
  eyebrow="Learning"
  crumbs={[{ label: 'Tutorials' }]}
>
  {
    levels.length > 1 && (
      <div class="mb-6 flex flex-wrap gap-2">
        {levels.map((level) => (
          <a
            href={`/tutorials/category/${level}`}
            class="rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-medium capitalize text-fg-muted transition-colors hover:border-primary hover:text-primary"
          >
            {level}
          </a>
        ))}
      </div>
    )
  }

  {
    tutorials.length === 0 ? (
      <p class="text-fg-muted">Tutorials are coming soon.</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {tutorials.map((tutorial) => (
          <TutorialCard tutorial={tutorial} />
        ))}
      </div>
    )
  }
</PageLayout>
