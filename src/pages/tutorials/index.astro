---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Tag from '@components/Tag.astro';
import { formatDate, byDateDesc } from '@utils/format';
import { BookOpen } from '@lucide/astro';

const tutorials = (await getCollection('tutorials')).sort(byDateDesc((t) => t.data.pubDate));

const levelStyles = {
  beginner: 'bg-success/10 text-success',
  intermediate: 'bg-warning/10 text-warning',
  advanced: 'bg-primary-soft text-primary',
};
---

<PageLayout
  title="Tutorials"
  description="Step-by-step, hands-on guides for building agentic AI systems, from first principles to production."
  eyebrow="Learning"
  crumbs={[{ label: 'Tutorials' }]}
>
  {
    tutorials.length === 0 ? (
      <p class="text-fg-muted">Tutorials are coming soon.</p>
    ) : (
      <div class="space-y-4">
        {tutorials.map((tutorial) => (
          <a href={`/tutorials/${tutorial.id}`} class="card card-hover flex items-start gap-4 p-5">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary-soft text-primary">
              <BookOpen class="h-5 w-5" aria-hidden="true" />
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="text-base font-semibold text-fg">{tutorial.data.title}</h2>
                <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium capitalize', levelStyles[tutorial.data.level]]}>
                  {tutorial.data.level}
                </span>
              </div>
              <p class="mt-1 text-sm text-fg-muted">{tutorial.data.description}</p>
              <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-fg-faint">
                <time datetime={tutorial.data.pubDate.toISOString()}>{formatDate(tutorial.data.pubDate)}</time>
                {tutorial.data.tags.slice(0, 3).map((tag) => <Tag tag={tag} />)}
              </div>
            </div>
          </a>
        ))}
      </div>
    )
  }
</PageLayout>
