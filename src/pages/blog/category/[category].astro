---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import { byDateDesc } from '@utils/format';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map((p) => p.data.category))];
  return categories.map((category) => ({
    params: { category: category.toLowerCase().replace(/\s+/g, '-') },
    props: { category, posts: posts.filter((p) => p.data.category === category) },
  }));
}

const { category, posts } = Astro.props;
const sorted = posts.sort(byDateDesc((p) => p.data.pubDate));
---

<PageLayout
  title={category}
  description={`Articles in the "${category}" category.`}
  eyebrow="Category"
  crumbs={[{ label: 'Blog', href: '/blog' }, { label: category }]}
>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((post) => <BlogCard post={post} />)}
  </div>
</PageLayout>
