---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import Tag from '@components/Tag.astro';
import { byDateDesc } from '@utils/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(byDateDesc((p) => p.data.pubDate));
const categories = [...new Set(posts.map((p) => p.data.category))];
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<PageLayout
  title="Blog"
  description="Deep dives on agentic AI, LangGraph, MCP, RAG architectures, and production LLM engineering."
  eyebrow="Writing"
  crumbs={[{ label: 'Blog' }]}
>
  {
    categories.length > 1 && (
      <div class="mb-6 flex flex-wrap gap-2">
        {categories.map((category) => (
          <a
            href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}`}
            class="rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-medium text-fg-muted transition-colors hover:border-primary hover:text-primary"
          >
            {category}
          </a>
        ))}
      </div>
    )
  }

  {
    posts.length === 0 ? (
      <p class="text-fg-muted">No posts yet — check back soon.</p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    )
  }

  {
    tags.length > 0 && (
      <div class="mt-14 border-t border-line pt-8">
        <p class="mb-4 text-sm font-semibold text-fg-muted">Browse by tag</p>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Tag tag={tag} linked />
          ))}
        </div>
      </div>
    )
  }
</PageLayout>
