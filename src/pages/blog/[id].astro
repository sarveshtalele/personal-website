---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import BlogCard from '@components/BlogCard.astro';
import PrevNext from '@components/PrevNext.astro';
import { mdxComponents } from '@components/mdx-components';
import { byDateDesc } from '@utils/format';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post, allPosts: posts } }));
}

const { post, allPosts } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const minutesRead = (remarkPluginFrontmatter as { minutesRead?: number }).minutesRead;

const sorted = allPosts.sort(byDateDesc((p) => p.data.pubDate));
const index = sorted.findIndex((p) => p.id === post.id);
const newer = index > 0 ? sorted[index - 1] : undefined;
const older = index < sorted.length - 1 ? sorted[index + 1] : undefined;

const related = sorted
  .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
  .slice(0, 3);
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  minutesRead={minutesRead}
  tags={post.data.tags}
  category={post.data.category}
  heroImage={post.data.heroImage}
  headings={headings}
  crumbs={[{ label: 'Blog', href: '/blog' }, { label: post.data.title }]}
  showShare
  showComments
>
  <Content components={mdxComponents} />

  <PrevNext
    prev={older && { href: `/blog/${older.id}`, title: older.data.title }}
    next={newer && { href: `/blog/${newer.id}`, title: newer.data.title }}
  />

  {
    related.length > 0 && (
      <div class="mt-14 border-t border-line pt-8">
        <p class="mb-5 text-sm font-semibold uppercase tracking-widest text-fg-faint">Related posts</p>
        <div class="grid gap-6 sm:grid-cols-3">
          {related.map((p) => (
            <BlogCard post={p} />
          ))}
        </div>
      </div>
    )
  }
</ArticleLayout>
