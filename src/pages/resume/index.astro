---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Timeline from '@components/Timeline.astro';
import Button from '@components/Button.astro';
import { GraduationCap, Mail, MapPin, Download, Printer } from '@lucide/astro';
import GithubIcon from '@components/icons/GithubIcon.astro';
import LinkedinIcon from '@components/icons/LinkedinIcon.astro';
import OrcidIcon from '@components/icons/OrcidIcon.astro';
import { SITE, SOCIALS, SKILLS, EDUCATION, ACHIEVEMENTS } from '@lib/site';
import { byDateDesc } from '@utils/format';

const experience = (await getCollection('experience')).sort(byDateDesc((e) => e.data.startDate));
const projects = (await getCollection('projects', ({ data }) => data.featured)).sort(byDateDesc((p) => p.data.pubDate));
const certifications = (await getCollection('certifications')).sort(byDateDesc((c) => c.data.date));
const publications = (await getCollection('publications')).sort(byDateDesc((p) => p.data.pubDate));
---

<BaseLayout title="Resume" description={`Resume of ${SITE.author} — ${SITE.role}.`}>
  <Container size="narrow" class="print-page py-12">
    <div class="no-print mb-8 flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-line bg-bg-alt px-5 py-4">
      <p class="text-sm text-fg-muted">This page is print- and PDF-friendly — use the buttons or your browser's print dialog.</p>
      <div class="flex gap-2">
        <Button href="/resume.pdf" variant="secondary" download>
          <Download class="h-4 w-4" aria-hidden="true" /> Download PDF
        </Button>
        <button
          type="button"
          onclick="window.print()"
          class="inline-flex items-center gap-2 rounded-xl border border-line bg-surface px-5 py-2.5 text-sm font-medium text-fg transition-colors hover:bg-bg"
        >
          <Printer class="h-4 w-4" aria-hidden="true" /> Print
        </button>
      </div>
    </div>

    <header class="border-b border-line pb-6">
      <h1 class="text-3xl font-bold tracking-tight text-fg">{SITE.author}</h1>
      <p class="mt-1 text-lg text-fg-muted">{SITE.role}</p>
      <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-fg-faint">
        <span class="inline-flex items-center gap-1.5"><Mail class="h-4 w-4" aria-hidden="true" /> {SITE.email}</span>
        <span class="inline-flex items-center gap-1.5"><MapPin class="h-4 w-4" aria-hidden="true" /> {SITE.location}</span>
        <a href={SOCIALS.github} class="inline-flex items-center gap-1.5 hover:text-primary"><GithubIcon class="h-4 w-4" /> github.com/sarveshtalele</a>
        <a href={SOCIALS.linkedin} class="inline-flex items-center gap-1.5 hover:text-primary"><LinkedinIcon class="h-4 w-4" /> linkedin.com/in/sarveshtalele</a>
        <a href={SOCIALS.scholar} class="inline-flex items-center gap-1.5 hover:text-primary"><GraduationCap class="h-4 w-4" aria-hidden="true" /> Google Scholar</a>
        <a href={SOCIALS.orcid} class="inline-flex items-center gap-1.5 hover:text-primary"><OrcidIcon class="h-4 w-4" /> ORCID</a>
      </div>
    </header>

    <section class="mt-8">
      <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Skills</h2>
      <div class="mt-3 space-y-3">
        {
          SKILLS.map((group) => (
            <div class="flex flex-col gap-1 sm:flex-row sm:gap-3">
              <p class="w-48 shrink-0 text-sm font-semibold text-fg">{group.group}</p>
              <p class="text-sm text-fg-muted">{group.items.join(', ')}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Experience</h2>
      <div class="mt-4">
        <Timeline entries={experience} />
      </div>
    </section>

    {
      projects.length > 0 && (
        <section class="mt-10">
          <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Projects</h2>
          <div class="mt-4 space-y-4">
            {projects.map((project) => (
              <div>
                <p class="font-semibold text-fg">
                  {project.data.title}
                  {project.data.github && (
                    <a href={project.data.github} class="ml-2 text-sm font-normal text-primary hover:text-primary-strong">
                      (Link)
                    </a>
                  )}
                </p>
                <p class="mt-1 text-sm text-fg-muted">{project.data.description}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-10">
      <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Education</h2>
      <div class="mt-4 space-y-3">
        {
          EDUCATION.map((edu) => (
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <div>
                <p class="font-semibold text-fg">{edu.degree}</p>
                <p class="text-sm text-fg-muted">{edu.institution}</p>
              </div>
              <p class="text-sm text-fg-faint">{edu.year} · {edu.detail}</p>
            </div>
          ))
        }
      </div>
    </section>

    {
      publications.length > 0 && (
        <section class="mt-10">
          <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Research Papers</h2>
          <div class="mt-4 space-y-2">
            {publications.map((pub) => (
              <p class="text-sm text-fg-muted">
                <span class="font-medium text-fg">{pub.data.title}</span> — Published in {pub.data.venue}
              </p>
            ))}
          </div>
        </section>
      )
    }

    {
      certifications.length > 0 && (
        <section class="mt-10">
          <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Certifications</h2>
          <ul class="mt-4 space-y-1.5 text-sm text-fg-muted">
            {certifications.map((cert) => (
              <li>{cert.data.title}, <span class="font-medium text-fg">{cert.data.issuer}</span></li>
            ))}
          </ul>
        </section>
      )
    }

    {
      ACHIEVEMENTS.length > 0 && (
        <section class="mt-10 mb-4">
          <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Achievements</h2>
          <ul class="mt-4 space-y-1.5 text-sm text-fg-muted">
            {ACHIEVEMENTS.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )
    }
  </Container>
</BaseLayout>
