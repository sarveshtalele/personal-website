---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import ResourceCard from '@components/ResourceCard.astro';

export async function getStaticPaths() {
  const resources = await getCollection('resources');
  const categories = [...new Set(resources.map((r) => r.data.category))];
  return categories.map((category) => ({
    params: { category: category.toLowerCase().replace(/\s+/g, '-') },
    props: { category, resources: resources.filter((r) => r.data.category === category) },
  }));
}

const { category, resources } = Astro.props;
---

<PageLayout
  title={category}
  description={`Resources in the "${category}" category.`}
  eyebrow="Category"
  crumbs={[{ label: 'Resources', href: '/resources' }, { label: category }]}
>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {resources.map((resource) => <ResourceCard resource={resource} />)}
  </div>
</PageLayout>
