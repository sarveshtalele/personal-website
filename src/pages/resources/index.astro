---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import { ExternalLink } from '@lucide/astro';

const resources = await getCollection('resources');
const grouped = new Map<string, typeof resources>();
for (const resource of resources) {
  const list = grouped.get(resource.data.category) ?? [];
  list.push(resource);
  grouped.set(resource.data.category, list);
}
---

<PageLayout
  title="Resources"
  description="Curated tools, papers, docs, and references I keep coming back to for AI engineering."
  eyebrow="Curated"
  crumbs={[{ label: 'Resources' }]}
>
  {
    resources.length === 0 ? (
      <p class="text-fg-muted">Resources are coming soon.</p>
    ) : (
      <div class="space-y-10">
        {[...grouped.entries()].map(([category, items]) => (
          <div>
            <h2 class="mb-4 text-lg font-semibold text-fg">{category}</h2>
            <div class="grid gap-3 sm:grid-cols-2">
              {items.map((resource) => (
                <a
                  href={resource.data.url}
                  target="_blank"
                  rel="noopener"
                  class="card card-hover flex items-start justify-between gap-3 p-4"
                >
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-fg">{resource.data.title}</p>
                    <p class="mt-1 line-clamp-2 text-sm text-fg-muted">{resource.data.description}</p>
                  </div>
                  <ExternalLink class="h-4 w-4 shrink-0 text-fg-faint" aria-hidden="true" />
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    )
  }
</PageLayout>
