---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Timeline from '@components/Timeline.astro';
import { byDateDesc } from '@utils/format';

const experience = (await getCollection('experience')).sort(byDateDesc((e) => e.data.startDate));
---

<PageLayout
  title="Experience"
  description="My professional journey building AI systems at enterprise scale."
  eyebrow="Career"
  crumbs={[{ label: 'Experience' }]}
>
  <Timeline entries={experience} />
</PageLayout>
