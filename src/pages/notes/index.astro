---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import NoteCard from '@components/NoteCard.astro';
import { byDateDesc } from '@utils/format';

const notes = (await getCollection('notes')).sort(byDateDesc((n) => n.data.updatedDate ?? n.data.pubDate));
const tags = [...new Set(notes.flatMap((n) => n.data.tags))].sort();
---

<PageLayout
  title="Notes"
  description="Short, searchable notes on Docker, Git, Linux, Regex, Python, SQL, Azure, FastAPI, LangGraph, MCP, and prompt engineering."
  eyebrow="Knowledge Base"
  crumbs={[{ label: 'Notes' }]}
>
  {
    tags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a
            href={`/notes/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
            class="rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-medium text-fg-muted transition-colors hover:border-primary hover:text-primary"
          >
            {tag}
          </a>
        ))}
      </div>
    )
  }

  {
    notes.length === 0 ? (
      <p class="text-fg-muted">Notes are coming soon.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {notes.map((note) => (
          <NoteCard note={note} />
        ))}
      </div>
    )
  }
</PageLayout>
