---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import NoteCard from '@components/NoteCard.astro';
import { slugifyTag, byDateDesc } from '@utils/format';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  const tags = [...new Set(notes.flatMap((n) => n.data.tags))];
  return tags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { tag, notes: notes.filter((n) => n.data.tags.includes(tag)) },
  }));
}

const { tag, notes } = Astro.props;
const sorted = notes.sort(byDateDesc((n) => n.data.pubDate));
---

<PageLayout
  title={`#${tag}`}
  description={`Notes tagged "${tag}".`}
  eyebrow="Tag"
  crumbs={[{ label: 'Notes', href: '/notes' }, { label: `#${tag}` }]}
>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {sorted.map((note) => <NoteCard note={note} />)}
  </div>
</PageLayout>
