---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
---

<BaseLayout title="Search" description="Search projects, publications, certifications, and Claude exam-prep pages.">
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />
  <Container size="narrow" class="py-14">
    <h1 class="text-3xl font-bold tracking-tight text-fg">Search</h1>
    <p class="mt-3 text-fg-muted">Search across every project, publication, and page on this site.</p>
    <div id="search" class="mt-8"></div>
    <p id="search-fallback" class="hidden text-sm text-fg-faint">
      The search index is generated during <code>pnpm build</code> and isn't available in dev mode. Run a
      production build to try it locally, or use the deployed site.
    </p>
  </Container>
</BaseLayout>

<script>
  function initPagefind() {
    const fallback = document.getElementById('search-fallback');

    // pagefind-ui.js is a plain browser global script (not ESM), generated at build
    // time by `pagefind --site dist`, it doesn't exist during `astro dev`, so a
    // failed <script> load means we're in dev mode and should show the fallback.
    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      // @ts-expect-error, global registered by the script above
      new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
    };
    script.onerror = () => fallback?.classList.remove('hidden');
    document.head.appendChild(script);
  }
  initPagefind();
</script>

<style is:global>
  #search {
    --pagefind-ui-primary: var(--primary);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--card);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-font: var(--font-sans, inherit);
  }
</style>
