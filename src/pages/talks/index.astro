---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import { Mic, ExternalLink, CirclePlay } from '@lucide/astro';
import { formatDate, byDateDesc } from '@utils/format';

const talks = (await getCollection('talks')).sort(byDateDesc((t) => t.data.date));
---

<PageLayout
  title="Talks"
  description="Conference talks, meetups, and workshops on agentic AI and LLM engineering."
  eyebrow="Speaking"
  crumbs={[{ label: 'Talks' }]}
>
  {
    talks.length === 0 ? (
      <p class="text-fg-muted">No talks listed yet.</p>
    ) : (
      <div class="space-y-4">
        {talks.map((talk) => (
          <div class="card p-6">
            <div class="flex items-start gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary-soft text-primary">
                <Mic class="h-5 w-5" aria-hidden="true" />
              </span>
              <div class="min-w-0">
                <h2 class="text-base font-semibold text-fg">{talk.data.title}</h2>
                <p class="mt-1 text-sm text-fg-muted">{talk.data.description}</p>
                <p class="mt-2 text-sm text-fg-faint">
                  {talk.data.event} · {formatDate(talk.data.date)}
                  {talk.data.location && ` · ${talk.data.location}`}
                </p>
                <div class="mt-3 flex gap-4 text-sm">
                  {talk.data.slides && (
                    <a href={talk.data.slides} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 font-medium text-primary hover:text-primary-strong">
                      <ExternalLink class="h-4 w-4" aria-hidden="true" /> Slides
                    </a>
                  )}
                  {talk.data.video && (
                    <a href={talk.data.video} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 font-medium text-primary hover:text-primary-strong">
                      <CirclePlay class="h-4 w-4" aria-hidden="true" /> Video
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }
</PageLayout>
