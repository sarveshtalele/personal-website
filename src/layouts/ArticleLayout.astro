---
import type { MarkdownHeading } from 'astro';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Container from '@components/Container.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import TableOfContents from '@components/TableOfContents.astro';
import ShareButtons from '@components/ShareButtons.astro';
import Tag from '@components/Tag.astro';
import Giscus from '@components/Giscus.astro';
import { formatDate } from '@utils/format';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  minutesRead?: number;
  tags?: string[];
  category?: string;
  heroImage?: ImageMetadata;
  headings: MarkdownHeading[];
  crumbs: Crumb[];
  showShare?: boolean;
  showComments?: boolean;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  minutesRead,
  tags = [],
  category,
  heroImage,
  headings,
  crumbs,
  showShare = false,
  showComments = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage?.src}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
>
  <Container size="wide" class="py-10 sm:py-14">
    <Breadcrumbs crumbs={crumbs} />
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_15rem]">
      <article class="min-w-0">
        <header class="max-w-[50rem]">
          {category && <p class="text-sm font-semibold uppercase tracking-widest text-primary">{category}</p>}
          <h1 class="mt-3 text-3xl font-bold tracking-tight text-fg sm:text-4xl">{title}</h1>
          <p class="mt-4 text-lg text-fg-muted">{description}</p>
          <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-fg-faint">
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            {updatedDate && <span>· Updated {formatDate(updatedDate)}</span>}
            {minutesRead && <span>· {minutesRead} min read</span>}
          </div>
          {
            tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <Tag tag={tag} linked />
                ))}
              </div>
            )
          }
          {showShare && <div class="mt-6"><ShareButtons title={title} url={canonicalURL} /></div>}
        </header>

        {
          heroImage && (
            <Image
              src={heroImage}
              alt=""
              width={1000}
              height={520}
              class="mt-8 max-w-[50rem] rounded-2xl border border-line object-cover"
            />
          )
        }

        <div class="prose mt-10">
          <slot />
        </div>

        <slot name="after" />

        {showComments && <Giscus />}
      </article>

      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>
