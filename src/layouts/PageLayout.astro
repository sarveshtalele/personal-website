---
import BaseLayout from './BaseLayout.astro';
import Container from '@components/Container.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  crumbs?: Crumb[];
  image?: string;
}
const { title, description, eyebrow, crumbs, image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <Container class="py-10 sm:py-14">
    {crumbs && <Breadcrumbs crumbs={crumbs} />}
    <header class="max-w-2xl">
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-widest text-primary">{eyebrow}</p>}
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-fg sm:text-4xl">{title}</h1>
      <p class="mt-4 text-lg text-fg-muted">{description}</p>
    </header>
    <div class="mt-10">
      <slot />
    </div>
  </Container>
</BaseLayout>
